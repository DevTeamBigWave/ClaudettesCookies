# ─────────────────────────────────────────────────────────────────────────────
# Claudette's Cookies — environment variables
# Copy to .env.local for development. In production set these in Railway.
# ─────────────────────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=development

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Server-only. Bypasses RLS — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Stripe (Dashboard → Developers → API keys)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# From `stripe listen` locally, or the webhook endpoint signing secret in prod.
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (Dashboard → API Keys)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL="Claudette's Cookies <hello@claudettescookies.shop>"
RESEND_REPLY_TO=claudettescookies@gmail.com

# Cron security — cron endpoints require `Authorization: Bearer ${CRON_SECRET}`.
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-with-a-long-random-string

# Admin bootstrap — comma-separated emails granted the `admin` role on first login.
ADMIN_EMAILS=accounting@bigwave.nyc,claudettescookies@gmail.com

# ─────────────────────────────────────────────────────────────────────────────
# Analytics & ad-conversion tracking (all optional — leave blank to ship no tags)
# ─────────────────────────────────────────────────────────────────────────────
# Google Analytics 4 measurement id (Admin → Data Streams). Web analytics.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Google Ads conversion id (Tools → Conversions → tag). Optimizes paid campaigns.
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXX
# Full `send_to` for the purchase conversion action: AW-XXXXXXXXX/AbC-dEfGhIjK
NEXT_PUBLIC_GOOGLE_ADS_PURCHASE_LABEL=AW-XXXXXXXXX/XXXXXXXXXXXXXXXXXXX
# Meta (Facebook/Instagram) Pixel id (Events Manager). Ad optimization + retargeting.
NEXT_PUBLIC_META_PIXEL_ID=XXXXXXXXXXXXXXX
